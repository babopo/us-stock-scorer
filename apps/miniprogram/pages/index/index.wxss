.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 44rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0f172a 0%, #111827 46%, #020617 100%);
  color: #f8fafc;
}

.query-panel,
.panel {
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.82);
  box-shadow: 0 24rpx 72rpx rgba(2, 6, 23, 0.34);
  box-sizing: border-box;
}

.query-panel {
  padding: 28rpx;
}

.panel {
  padding: 24rpx;
}

.brand-row,
.toolbar,
.ticker-row,
.section-head,
.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.brand-row {
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.app-title {
  display: block;
  color: #f8fafc;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.app-caption,
.data-date,
.section-subtitle,
.company,
.score-unit,
.decision-copy,
.line,
.evidence {
  display: block;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.55;
}

.data-date,
.factor-count {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(251, 191, 36, 0.28);
  border-radius: 14rpx;
  color: #fbbf24;
  background: rgba(245, 158, 11, 0.1);
  font-size: 22rpx;
}

.ticker-input {
  flex: 1;
  height: 80rpx;
  min-width: 0;
  padding: 0 22rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.32);
  border-radius: 14rpx;
  background: rgba(2, 6, 23, 0.42);
  color: #f8fafc;
  font-size: 28rpx;
  box-sizing: border-box;
}

.query-button {
  width: 152rpx;
  height: 80rpx;
  margin: 0;
  padding: 0;
  border-radius: 14rpx;
  background: #f59e0b;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 80rpx;
}

.query-button::after {
  border: 0;
}

.error {
  margin-bottom: 20rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.34);
  border-radius: 16rpx;
  background: rgba(127, 29, 29, 0.32);
  color: #fecaca;
  font-size: 26rpx;
  line-height: 1.5;
}

.summary {
  background: linear-gradient(160deg, rgba(15, 23, 42, 0.92), rgba(30, 41, 59, 0.74));
}

.ticker-row {
  align-items: flex-start;
}

.ticker {
  display: block;
  color: #f8fafc;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.company {
  max-width: 420rpx;
  margin-top: 8rpx;
  color: #cbd5e1;
}

.price {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(56, 189, 248, 0.28);
  border-radius: 14rpx;
  color: #67e8f9;
  background: rgba(8, 47, 73, 0.34);
  font-size: 24rpx;
  font-weight: 700;
}

.score-grid {
  display: flex;
  gap: 16rpx;
  margin: 28rpx 0 24rpx;
}

.score-box {
  flex: 1;
  min-width: 0;
  padding: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 16rpx;
  background: rgba(2, 6, 23, 0.36);
}

.score-label {
  display: block;
  color: #cbd5e1;
  font-size: 24rpx;
  line-height: 1.3;
}

.score-value {
  display: block;
  margin-top: 8rpx;
  color: #fbbf24;
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.05;
}

.score-unit {
  margin-top: 4rpx;
}

.decision {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.decision-title,
.section-title {
  display: block;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.radar-panel {
  overflow: hidden;
}

.radar-stage {
  position: relative;
  height: 620rpx;
  margin: 18rpx 0 16rpx;
}

.radar-canvas {
  width: 100%;
  height: 100%;
}

.factor-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.factor-tab {
  display: flex;
  width: calc((100% - 12rpx) / 2);
  min-height: 76rpx;
  padding: 12rpx 14rpx;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  border-radius: 14rpx;
  background: rgba(2, 6, 23, 0.34);
  box-sizing: border-box;
}

.factor-tab.is-active {
  border-color: rgba(251, 191, 36, 0.84);
  background: #f59e0b;
}

.factor-tab-name,
.factor-tab-score {
  display: block;
}

.factor-tab-name {
  flex: 1;
  min-width: 0;
  color: #cbd5e1;
  font-size: 22rpx;
  line-height: 1.25;
}

.factor-tab-score {
  flex-shrink: 0;
  color: #f8fafc;
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.factor-tab.is-active .factor-tab-name,
.factor-tab.is-active .factor-tab-score {
  color: #111827;
}

.factor-detail {
  padding: 22rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 16rpx;
  background: rgba(2, 6, 23, 0.38);
}

.detail-title {
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.detail-score {
  flex-shrink: 0;
  color: #fbbf24;
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 28rpx;
  font-weight: 800;
}

.score-meter {
  height: 10rpx;
  margin: 18rpx 0 6rpx;
  overflow: hidden;
  border-radius: 10rpx;
  background: rgba(148, 163, 184, 0.18);
}

.score-meter-fill {
  height: 100%;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #38bdf8, #fbbf24);
}

.evidence-list {
  margin-top: 10rpx;
}

.evidence,
.line {
  margin-top: 14rpx;
  padding-left: 18rpx;
  border-left: 4rpx solid rgba(56, 189, 248, 0.58);
  color: #cbd5e1;
}

.section .section-title {
  margin-bottom: 8rpx;
}
