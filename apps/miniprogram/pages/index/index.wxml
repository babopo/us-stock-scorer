<view class="page">
  <view class="query-panel">
    <view class="brand-row">
      <view>
        <text class="app-title">美股五因子评分</text>
        <text class="app-caption">中长期质量与短期买点分开判断</text>
      </view>
      <text wx:if="{{score}}" class="data-date">{{score.data_as_of}}</text>
    </view>
    <view class="toolbar">
      <input class="ticker-input" value="{{ticker}}" bindinput="onTickerInput" bindconfirm="fetchScore" placeholder="输入美股代码" confirm-type="search" />
      <button class="query-button" bindtap="fetchScore" loading="{{loading}}">查询</button>
    </view>
  </view>

  <view wx:if="{{error}}" class="error" aria-role="alert">{{error}}</view>

  <view wx:if="{{score}}" class="summary panel">
    <view class="ticker-row">
      <view>
        <text class="ticker">{{score.ticker}}</text>
        <text class="company">{{score.company_name}}</text>
      </view>
      <text class="price">${{score.last_price}}</text>
    </view>
    <view class="score-grid">
      <view class="score-box">
        <text class="score-label">中长期</text>
        <text class="score-value">{{score.medium_term_score}}</text>
        <text class="score-unit">3-12个月</text>
      </view>
      <view class="score-box">
        <text class="score-label">1-2周</text>
        <text class="score-value">{{score.short_term_score}}</text>
        <text class="score-unit">买点状态</text>
      </view>
    </view>
    <view class="decision">
      <text class="decision-title">当前行动</text>
      <text class="decision-copy">{{score.decision.summary}}</text>
    </view>
  </view>

  <view wx:if="{{score}}" class="radar-panel panel">
    <view class="section-head">
      <view>
        <text class="section-title">五因子图</text>
        <text class="section-subtitle">点击任一维度查看证据</text>
      </view>
      <text class="factor-count">{{radarFactors.length}} 维</text>
    </view>

    <view class="radar-stage">
      <canvas id="factorRadar" canvas-id="factorRadar" class="radar-canvas" bindtap="onRadarTap"></canvas>
    </view>

    <view class="factor-tabs">
      <view wx:for="{{radarFactors}}" wx:key="name" class="factor-tab {{selectedFactorIndex == item.index ? 'is-active' : ''}}" data-index="{{item.index}}" bindtap="selectRadarFactor">
        <text class="factor-tab-name">{{item.name}}</text>
        <text class="factor-tab-score">{{item.score}}</text>
      </view>
    </view>

    <view wx:if="{{selectedFactor}}" class="factor-detail">
      <view class="detail-head">
        <text class="detail-title">{{selectedFactor.name}}</text>
        <text class="detail-score">{{selectedFactor.score}}/100</text>
      </view>
      <view class="score-meter">
        <view class="score-meter-fill" style="width: {{selectedFactor.percent}}%;"></view>
      </view>
      <view class="evidence-list">
        <text wx:for="{{selectedFactor.evidence}}" wx:key="*this" class="evidence">{{item}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{score}}" class="section panel">
    <text class="section-title">触发条件</text>
    <text wx:for="{{score.decision.trigger_conditions}}" wx:key="*this" class="line">{{item}}</text>
  </view>

  <view wx:if="{{score}}" class="section panel">
    <text class="section-title">失效条件</text>
    <text wx:for="{{score.decision.invalidation_conditions}}" wx:key="*this" class="line">{{item}}</text>
  </view>

  <view wx:if="{{score}}" class="section panel">
    <text class="section-title">风险提示</text>
    <text wx:for="{{score.decision.risks}}" wx:key="*this" class="line">{{item}}</text>
  </view>
</view>
