{
  "name": "us-stock-scorer",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @stock-scorer/api-client build && pnpm --filter @stock-scorer/admin build",
    "test": "pnpm build && node --import tsx --test packages/api-client/test/*.test.ts test/*.test.ts && pnpm --filter @stock-scorer/admin test",
    "typecheck": "tsc -b packages/api-client apps/admin && tsc --noEmit -p packages/api-client/tsconfig.test.json"
  },
  "workspaces": [
    "apps/admin",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
